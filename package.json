{
  "name": "pulse-version-1.1.0",
  "version": "1.0.0",
  "description": "Playwright end-to-end test framework for Pulse",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:chromium": "playwright test --project=setup --project=chromium",
    "test:auth": "playwright test --project=anonymous",
    "test:crossbrowser": "playwright test --project=setup --project=firefox --project=webkit",
    "test:responsive": "playwright test --project=setup --project=tablet --project=mobile",
    "test:smoke": "playwright test --project=setup --project=chromium specs/navigation.spec.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "dotenv": "^17.4.2"
  }
}
