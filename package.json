{
  "name": "pulse-version-1.1.0",
  "version": "1.0.0",
  "description": "Playwright end-to-end test framework for Pulse",
  "main": "index.js",
  "scripts": {
    "pw": "node node_modules/@playwright/test/cli.js",
    "test": "node node_modules/@playwright/test/cli.js test",
    "test:headed": "node node_modules/@playwright/test/cli.js test --headed",
    "test:ui": "node node_modules/@playwright/test/cli.js test --ui",
    "test:debug": "node node_modules/@playwright/test/cli.js test --debug",
    "report": "node node_modules/@playwright/test/cli.js show-report",
    "test:last-failed": "node node_modules/@playwright/test/cli.js test --last-failed",
    "test:chrome": "node node_modules/@playwright/test/cli.js test --project=chrome",
    "test:edge": "node node_modules/@playwright/test/cli.js test --project=edge",
    "test:firefox": "node node_modules/@playwright/test/cli.js test --project=firefox",
    "test:brave": "node node_modules/@playwright/test/cli.js test --project=brave",
    "test:all-browsers": "node node_modules/@playwright/test/cli.js test --project=chrome --project=edge --project=firefox --project=brave",
    "test:resolutions": "node node_modules/@playwright/test/cli.js test --project=tablet --project=mobile",
    "test:performance": "node node_modules/@playwright/test/cli.js test --project=performance",
    "test:security": "node node_modules/@playwright/test/cli.js test --project=anonymous",
    "test:auth": "node node_modules/@playwright/test/cli.js test --project=chrome specs/auth",
    "test:core": "node node_modules/@playwright/test/cli.js test --project=chrome specs/core",
    "test:ai": "node node_modules/@playwright/test/cli.js test --project=chrome specs/ai specs/ai-engineer",
    "test:monitoring": "node node_modules/@playwright/test/cli.js test --project=chrome specs/monitoring",
    "test:operations": "node node_modules/@playwright/test/cli.js test --project=chrome specs/operations",
    "test:settings": "node node_modules/@playwright/test/cli.js test --project=chrome specs/settings",
    "test:shell": "node node_modules/@playwright/test/cli.js test --project=chrome specs/shell",
    "test:hierarchy": "node node_modules/@playwright/test/cli.js test --project=chrome specs/hierarchy specs/asset-detail",
    "test:quality": "node node_modules/@playwright/test/cli.js test --project=chrome specs/quality",
    "test:smoke": "node node_modules/@playwright/test/cli.js test --project=chrome tests/e2e/smoke/",
    "test:sanity": "node node_modules/@playwright/test/cli.js test --project=chrome tests/e2e/sanity/",
    "test:regression": "node node_modules/@playwright/test/cli.js test --project=chrome tests/e2e/regression/",
    "test:e2e": "node node_modules/@playwright/test/cli.js test --project=chrome tests/e2e/e2e/",
    "test:ui-checks": "node node_modules/@playwright/test/cli.js test --project=chrome tests/e2e/ui/",
    "test:a11y": "node node_modules/@playwright/test/cli.js test --project=accessibility",
    "test:security:full": "node node_modules/@playwright/test/cli.js test --project=chrome --project=anonymous tests/e2e/security/",
    "test:integration": "node node_modules/@playwright/test/cli.js test --project=chrome tests/e2e/integration/",
    "test:qa": "node node_modules/@playwright/test/cli.js test --project=chrome --project=anonymous --project=accessibility tests/e2e/smoke/ tests/e2e/sanity/ tests/e2e/regression/ tests/e2e/e2e/ tests/e2e/ui/ tests/e2e/accessibility/ tests/e2e/security/ tests/e2e/integration/",
    "report:build": "node scripts/build-reports.cjs"
  },
  "keywords": [],
